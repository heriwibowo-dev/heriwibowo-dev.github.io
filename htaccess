
# Aktifkan modul rewrite
RewriteEngine On

# Menghapus ekstensi .html dari URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.html [L]

# Pengaturan tambahan untuk memastikan URL yang bersih (tidak ada trailing slash)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/$ /$1 [L,R=301]
